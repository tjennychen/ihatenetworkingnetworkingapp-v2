{
  "manifest_version": 3,
  "name": "I Hate Networking",
  "version": "1.3.1",
  "description": "Connect with Luma event attendees on LinkedIn",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "activeTab",
    "cookies",
    "sidePanel"
  ],
  "host_permissions": [
    "https://lu.ma/*",
    "https://*.lu.ma/*",
    "https://luma.com/*",
    "https://www.linkedin.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lu.ma/*",
        "https://*.lu.ma/*",
        "https://luma.com/*"
      ],
      "js": [
        "dist/luma.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "dist/linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://ihatenetworking.space/login*"
      ],
      "js": [
        "dist/login-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "I Hate Networking",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "externally_connectable": {
    "matches": [
      "https://*.vercel.app/*",
      "https://ihatenetworking.space/*"
    ]
  }
}
